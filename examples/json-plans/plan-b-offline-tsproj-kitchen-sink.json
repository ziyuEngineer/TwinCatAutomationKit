{
  "schemaVersion": 1,
  "name": "plan-b-offline-tsproj-kitchen-sink",
  "variables": {
    "root": "${plan.dir}\\PlanB",
    "solutionName": "PlanB",
    "projectName": "PlanB",
    "cppProjectName": "CppB",
    "plcProjectName": "PlcB",
    "plcInstanceName": "PlcInst01",
    "cppInstanceBaseName": "CppB_Obj1",
    "cppInstanceName": "CppB_Obj1 (CppB)",
    "offlineInstanceName": "CppB_Obj2 (CppB)",
    "offlineInstanceObjectId": "#x02010030",
    "solutionPath": "${root}\\${solutionName}.sln",
    "projectPath": "${root}\\${projectName}\\${projectName}.tsproj",
    "payloadDir": "${root}\\_json_plan_payloads",
    "evidenceDir": "${root}\\_json_plan_evidence",
    "taskName": "Task1",
    "taskPriority": 15,
    "taskCycleTimeNs": 10000000,
    "taskCycleTimeUs": 10000,
    "taskAmsPort": 360,
    "includeActivation": false
  },
  "defaults": {
    "solution-path": "${solutionPath}",
    "project-path": "${projectPath}",
    "visible": false,
    "startup-delay-ms": 8000
  },
  "files": [
    {
      "path": "${payloadDir}\\datatypes.xml",
      "content": "<DataTypes>\n  <DataType><Name>ST_PlanBSignal</Name></DataType>\n  <DataType><Name>ST_PlanBDiag</Name></DataType>\n</DataTypes>\n"
    },
    {
      "path": "${root}\\${projectName}\\${plcProjectName}\\POUs\\MAIN.TcPOU",
      "content": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<TcPlcObject>\n  <POU Name=\"MAIN\">\n    <Declaration><![CDATA[\nPROGRAM MAIN\nVAR\n    nSeed : UDINT := 9;\n    nStage1 : UDINT;\n    bHeartbeat : BOOL;\nEND_VAR\n    ]]></Declaration>\n    <Implementation>\n      <ST><![CDATA[\n(* plan-b-kitchen-sink -- plcproj: ${steps.createPlcProject.outputs.projectFilePath} *)\nbHeartbeat := NOT bHeartbeat;\nnStage1 := nSeed + 789;\n      ]]></ST>\n    </Implementation>\n  </POU>\n</TcPlcObject>\n"
    },
    {
      "path": "${payloadDir}\\upsert-element.json",
      "content": {
        "parentPath": [
          { "elementName": "Project" },
          { "elementName": "System" }
        ],
        "elementName": "PlanBMetadata",
        "attributes": [
          { "name": "GeneratedBy", "value": "TwinCatAutomationKit" },
          { "name": "StepKind", "value": "tsproj.upsert-element" }
        ],
        "childValues": [
          { "elementName": "Description", "value": "Generic element upsert showcase — plan-b-kitchen-sink" },
          { "elementName": "PlanName", "value": "plan-b-offline-tsproj-kitchen-sink" }
        ],
        "conflictPolicy": 0
      }
    },
    {
      "path": "${payloadDir}\\upsert-fragment.json",
      "content": {
        "parentPath": [
          { "elementName": "Project" },
          { "elementName": "System" }
        ],
        "fragmentXml": "<PlanBFragment><Name>UpsertFragmentShowcase</Name><StepKind>tsproj.upsert-fragment</StepKind><Value>kitchen-sink-fragment-demo</Value></PlanBFragment>",
        "matchElementName": "PlanBFragment",
        "matchNameValue": "UpsertFragmentShowcase",
        "conflictPolicy": 0
      }
    },
    {
      "path": "${payloadDir}\\apply-mutation-plan.json",
      "content": {
        "elementUpserts": [
          {
            "parentPath": [
              { "elementName": "Project" },
              { "elementName": "System" }
            ],
            "elementName": "BatchMetadata",
            "attributes": [
              { "name": "Source", "value": "tsproj.apply-mutation-plan" }
            ],
            "childValues": [
              { "elementName": "ElementUpsertCount", "value": "1" },
              { "elementName": "FragmentUpsertCount", "value": "1" }
            ],
            "conflictPolicy": 0
          }
        ],
        "fragmentUpserts": [
          {
            "parentPath": [
              { "elementName": "Project" },
              { "elementName": "System" }
            ],
            "fragmentXml": "<BatchFragment><Name>PlanBBatch</Name><Description>Fragment upsert within apply-mutation-plan batch</Description></BatchFragment>",
            "matchElementName": "BatchFragment",
            "matchNameValue": "PlanBBatch",
            "conflictPolicy": 0
          }
        ]
      }
    }
  ],
  "steps": [
    {
      "id": "createSolution",
      "kind": "engineering.create-xae-solution",
      "options": {
        "solution-directory": "${root}",
        "solution-name": "${solutionName}",
        "project-name": "${projectName}"
      }
    },
    {
      "id": "createCppProject",
      "kind": "engineering.create-cpp-project",
      "options": {
        "cpp-project-name": "${cppProjectName}"
      }
    },
    {
      "id": "createPlcProject",
      "kind": "engineering.create-plc-project",
      "options": {
        "plc-project-name": "${plcProjectName}"
      }
    },
    {
      "id": "createModule",
      "kind": "engineering.create-module",
      "options": {
        "cpp-project-name": "${cppProjectName}",
        "module-name": "AuxModule",
        "allow-offline-fallback": true
      }
    },
    {
      "id": "addModuleInstance",
      "kind": "engineering.add-module-instance",
      "options": {
        "cpp-project-name": "${cppProjectName}",
        "instance-base-name": "${cppInstanceBaseName}",
        "module-class-name": "${cppProjectName}"
      }
    },
    {
      "id": "ensureTask",
      "kind": "engineering.ensure-task",
      "options": {
        "task-name": "${taskName}",
        "task-subtype": 0,
        "priority": "${taskPriority}",
        "cycle-time-us": "${taskCycleTimeUs}",
        "ams-port": "${taskAmsPort}",
        "io-at-begin": true
      }
    },
    {
      "id": "exportCppXmlBefore",
      "kind": "engineering.export-tree-item-xml",
      "options": {
        "tree-item-path": "TIXC^${cppProjectName}",
        "destination-path": "${evidenceDir}\\cpp.before-kitchen-sink.xml",
        "recursive": true
      }
    },
    {
      "id": "bindRealCppInstance",
      "kind": "tsproj.bind-instance-task",
      "options": {
        "instance-name": "${cppInstanceName}",
        "task-object-id": "${steps.ensureTask.outputs.objectId}",
        "priority": "${taskPriority}",
        "cycle-time-ns": "${taskCycleTimeNs}",
        "include-cyclic-caller": true
      }
    },
    {
      "id": "ensurePlcInstance",
      "kind": "tsproj.ensure-plc-instance",
      "options": {
        "plc-project-name": "${plcProjectName}",
        "plc-instance-name": "${plcInstanceName}"
      }
    },
    {
      "id": "bindPlcTask",
      "kind": "tsproj.bind-plc-instance-task",
      "options": {
        "plc-project-name": "${plcProjectName}",
        "plc-instance-name": "${plcInstanceName}",
        "plc-task-name": "${taskName}",
        "task-object-id": "${steps.ensureTask.outputs.objectId}",
        "priority": "${taskPriority}",
        "cycle-time-ns": "${taskCycleTimeNs}",
        "context-id": 0
      }
    },
    {
      "id": "setPlcProjectProperties",
      "kind": "tsproj.set-plc-project-properties",
      "options": {
        "plc-project-name": "${plcProjectName}",
        "ams-port": 851,
        "reload-tmc": true
      }
    },
    {
      "id": "replaceDataTypes",
      "kind": "tsproj.replace-data-types-section",
      "options": {
        "xml-file": "${payloadDir}\\datatypes.xml",
        "insert-before-project": true
      }
    },
    {
      "id": "offlineCppInstance",
      "kind": "tsproj.ensure-cpp-instance",
      "options": {
        "cpp-project-name": "${cppProjectName}",
        "instance-name": "${offlineInstanceName}",
        "object-id": "${offlineInstanceObjectId}",
        "context-id": 1,
        "context-name": "OfflineCtx",
        "priority": "${taskPriority}",
        "cycle-time-ns": "${taskCycleTimeNs}"
      }
    },
    {
      "id": "bindOfflineCtx",
      "kind": "tsproj.bind-instance-context",
      "options": {
        "instance-name": "${offlineInstanceName}",
        "task-object-id": "${steps.ensureTask.outputs.objectId}",
        "priority": "${taskPriority}",
        "cycle-time-ns": "${taskCycleTimeNs}",
        "context-id": 1,
        "context-name": "Task1Ctx",
        "include-cyclic-caller": true,
        "remove-cyclic-caller-when-excluded": false
      }
    },
    {
      "id": "ensureIoTaskImage",
      "kind": "tsproj.ensure-io-task-image",
      "options": {
        "task-name": "${taskName}",
        "instance-name": "${cppInstanceName}",
        "image-id": 1,
        "size-in": 40,
        "size-out": 10,
        "pointer-name": "IoTaskImage",
        "ensure-default-task-variables": true,
        "input-real-count": 10,
        "output-byte-count": 10,
        "io-at-begin": true
      }
    },
    {
      "id": "clearMappings",
      "kind": "tsproj.clear-mappings",
      "options": {}
    },
    {
      "id": "replaceMappingsSection",
      "kind": "tsproj.replace-mappings-section",
      "options": {
        "mappings-xml": "<Mappings></Mappings>"
      }
    },
    {
      "id": "replaceProjectIoSection",
      "kind": "tsproj.replace-project-io-section",
      "options": {
        "io-xml": "<Io></Io>"
      }
    },
    {
      "id": "upsertElement",
      "kind": "tsproj.upsert-element",
      "options": {
        "json-file": "${payloadDir}\\upsert-element.json"
      }
    },
    {
      "id": "upsertFragment",
      "kind": "tsproj.upsert-fragment",
      "options": {
        "json-file": "${payloadDir}\\upsert-fragment.json"
      }
    },
    {
      "id": "applyMutationPlan",
      "kind": "tsproj.apply-mutation-plan",
      "options": {
        "json-file": "${payloadDir}\\apply-mutation-plan.json"
      }
    },
    {
      "id": "exportCppXmlAfter",
      "kind": "engineering.export-tree-item-xml",
      "options": {
        "tree-item-path": "TIXC^${cppProjectName}",
        "destination-path": "${evidenceDir}\\cpp.after-kitchen-sink.xml",
        "recursive": true
      }
    },
    {
      "id": "exportTasksXml",
      "kind": "engineering.export-tree-item-xml",
      "options": {
        "tree-item-path": "TIRT",
        "destination-path": "${evidenceDir}\\tirt.after-io-image.xml",
        "recursive": true
      }
    },
    {
      "id": "buildSolution",
      "kind": "engineering.build-solution",
      "options": {
        "timeout-ms": 1800000
      }
    },
    {
      "id": "activate",
      "kind": "engineering.activate-configuration",
      "enabled": "${includeActivation}",
      "options": {
        "save-configuration-archive": true,
        "configuration-archive-path": "${evidenceDir}\\activated.tszip"
      }
    }
  ]
}
